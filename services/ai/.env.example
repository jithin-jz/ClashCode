# AI Service Settings
CORE_SERVICE_URL=http://core:8000
INTERNAL_API_KEY=replace-with-long-random-internal-key
INTERNAL_SIGNING_SECRET=replace-with-long-random-signing-secret
INTERNAL_REQUIRE_SIGNATURE=True

# LLM Providers
GROQ_API_KEY=replace-with-groq-key
MODEL_NAME=llama-3.3-70b-versatile
OPENAI_API_BASE=https://api.groq.com/openai/v1

# Vector DB
PINECONE_API_KEY=your_api_key_here
PINECONE_INDEX_NAME=clashcode
EMBEDDING_MODEL=llama-text-embed-v2

# Security
CORS_ORIGINS=https://your-domain.com
